<h1>Edit Task</h1>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <%= form_with(model: @task, local: true) do |form| %>
          <% if @task.errors.any? %>
            <div class="alert alert-danger">
              <h4><%= pluralize(@task.errors.count, "error") %> prohibited this task from being saved:</h4>
              <ul class="mb-0">
                <% @task.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= form.label :title, class: "form-label" %>
            <%= form.text_field :title, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, rows: 4, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :priority, class: "form-label" %>
            <%= form.select :priority, 
                [['Very Low', 1], ['Low', 2], ['Medium', 3], ['High', 4], ['Very High', 5]], 
                {}, 
                { class: "form-select" } %>
          </div>

          <div class="mb-3">
            <%= form.label :due_date, class: "form-label" %>
            <%= form.date_field :due_date, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.check_box :completed, class: "form-check-input" %>
            <%= form.label :completed, "Mark as completed", class: "form-check-label" %>
          </div>

          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <%= link_to "Cancel", @task, class: "btn btn-secondary" %>
            <%= form.submit "Update Task", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>