<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>My Tasks</h1>
  <%= link_to "New Task", new_task_path, class: "btn btn-primary" %>
</div>

<div class="row">
  <% if @tasks.any? %>
    <% @tasks.each do |task| %>
      <div class="col-md-6 mb-3">
        <div class="card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h5 class="card-title">
                  <%= task.title %>
                  <span class="badge bg-<%= task.priority_color %>"><%= task.priority_label %></span>
                </h5>
                <% if task.description.present? %>
                  <p class="card-text"><%= truncate(task.description, length: 100) %></p>
                <% end %>
                <% if task.due_date %>
                  <small class="text-muted">Due: <%= task.due_date.strftime("%B %d, %Y") %></small>
                <% end %>
              </div>
              <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="taskDropdown<%= task.id %>" data-bs-toggle="dropdown" aria-expanded="false">
                  Actions
                </button>
                <ul class="dropdown-menu" aria-labelledby="taskDropdown<%= task.id %>">
                  <li><%= link_to "View", task, class: "dropdown-item" %></li>
                  <li><%= link_to "Edit", edit_task_path(task), class: "dropdown-item" %></li>
                  <li>
                    <%= link_to toggle_completed_task_path(task), 
                                method: :patch, 
                                class: "dropdown-item" do %>
                      <%= task.completed? ? "Mark Incomplete" : "Mark Complete" %>
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to "Delete", task, 
                                method: :delete, 
                                data: { confirm: "Are you sure?" }, 
                                class: "dropdown-item text-danger" %>
                  </li>
                </ul>
              </div>
            </div>
            <% if task.completed? %>
              <span class="badge bg-success mt-2">Completed ✓</span>
            <% elsif task.overdue? %>
              <span class="badge bg-danger mt-2">Overdue ⚠️</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12">
      <div class="text-center py-5">
        <h3>No tasks yet</h3>
        <p class="text-muted">Get started by creating your first task!</p>
        <%= link_to "Create Task", new_task_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>