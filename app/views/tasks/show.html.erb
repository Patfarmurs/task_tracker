<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-body">
        <h1><%= @task.title %></h1>
        <div class="mb-3">
          <span class="badge bg-<%= @task.priority_color %>"><%= @task.priority_label %></span>
          <% if @task.completed? %>
            <span class="badge bg-success">Completed ✓</span>
          <% elsif @task.overdue? %>
            <span class="badge bg-danger">Overdue ⚠️</span>
          <% end %>
        </div>
        
        <% if @task.description.present? %>
          <div class="mb-3">
            <strong>Description:</strong>
            <p><%= simple_format(@task.description) %></p>
          </div>
        <% end %>
        
        <% if @task.due_date %>
          <div class="mb-3">
            <strong>Due Date:</strong>
            <%= @task.due_date.strftime("%B %d, %Y") %>
          </div>
        <% end %>
        
        <div class="mb-3">
          <strong>Status:</strong>
          <%= @task.completed? ? "Completed" : "In Progress" %>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5>Actions</h5>
      </div>
      <div class="card-body d-grid gap-2">
        <%= link_to "Edit Task", edit_task_path(@task), class: "btn btn-primary" %>
        <%= link_to toggle_completed_task_path(@task), method: :patch, 
                    class: "btn btn-success" do %>
          <%= @task.completed? ? "Mark Incomplete" : "Mark Complete" %>
        <% end %>
        <%= link_to "Delete Task", @task, 
                    method: :delete, 
                    data: { confirm: "Are you sure?" }, 
                    class: "btn btn-danger" %>
        <%= link_to "Back to Tasks", tasks_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>