<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>My Goals</h1>
  <%= link_to "New Goal", new_goal_path, class: "btn btn-primary" %>
</div>

<div class="row">
  <% if @goals.any? %>
    <% @goals.each do |goal| %>
      <div class="col-md-6 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= goal.title %></h5>
            <% if goal.description.present? %>
              <p class="card-text"><%= goal.description %></p>
            <% end %>
            
            <div class="progress mb-2">
              <div class="progress-bar bg-success" style="width: <%= goal.progress %>%">
                <%= goal.progress %>%
              </div>
            </div>
            
            <div class="mt-2">
              <%= link_to "View", goal, class: "btn btn-sm btn-primary" %>
              <%= link_to "Edit", edit_goal_path(goal), class: "btn btn-sm btn-secondary" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12">
      <div class="text-center py-5">
        <h3>No goals yet</h3>
        <p class="text-muted">Create your first goal!</p>
        <%= link_to "Create Goal", new_goal_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>