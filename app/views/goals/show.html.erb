<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-body">
        <h1><%= @goal.title %></h1>
        
        <div class="mb-4">
          <div class="progress">
            <div class="progress-bar bg-<%= @goal.progress_color %>" 
                 style="width: <%= @goal.progress %>%" 
                 aria-valuenow="<%= @goal.progress %>" 
                 aria-valuemin="0" 
                 aria-valuemax="100">
              <%= @goal.progress %>%
            </div>
          </div>
          <% if @goal.completed? %>
            <span class="badge bg-success mt-2">Completed ✓</span>
          <% end %>
        </div>
        
        <% if @goal.description.present? %>
          <div class="mb-3">
            <strong>Description:</strong>
            <p><%= simple_format(@goal.description) %></p>
          </div>
        <% end %>
        
        <% if @goal.target_date %>
          <div class="mb-3">
            <strong>Target Date:</strong>
            <%= @goal.target_date.strftime("%B %d, %Y") %>
            <% if @goal.days_remaining > 0 %>
              <small class="text-muted">(<%= pluralize(@goal.days_remaining, 'day') %> remaining)</small>
            <% elsif @goal.days_remaining == 0 %>
              <small class="text-warning">(Due today!)</small>
            <% else %>
              <small class="text-danger">(Overdue by <%= pluralize(@goal.days_remaining.abs, 'day') %>)</small>
            <% end %>
          </div>
        <% end %>
        
        <div class="mb-3">
          <strong>Progress:</strong>
          <%= @goal.progress %>% complete
        </div>
        
        <div class="mb-3">
          <strong>Status:</strong>
          <%= @goal.completed? ? "Completed" : "In Progress" %>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5>Actions</h5>
      </div>
      <div class="card-body d-grid gap-2">
        <%= link_to "Edit Goal", edit_goal_path(@goal), class: "btn btn-primary" %>
        <%= link_to "Delete Goal", @goal, method: :delete, 
                    confirm: "Are you sure?", class: "btn btn-danger" %>
        <%= link_to "Back to Goals", goals_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>